# WHITELIST REPO — everything is untracked unless re-included below
/*
!/.gitignore
!/.gitattributes
!/LICENSE
!/install.sh
!/README.md
!/SPEC.md
!/setup.md
!/folder-structure.md
!/AGENTS.md
!/CLAUDE.md
!/DEVELOPMENT.md
!/_agents/
!/_harness/
!/dev-loop/
!/Tickets/
!/General AI-Knowledge/
!/decisions/
!/.github/

# working bulk inside tickets is never a record
Tickets/*/Logs/*
Tickets/*/Dump/*
!Tickets/*/Logs/.gitkeep
!Tickets/*/Dump/.gitkeep

# OS noise + objective editor/tool junk — never records, safe to ignore everywhere (no data
# extensions: the user's own files stay tracked/sovereign). .DS_Store already covered above.
.DS_Store
**/.DS_Store
*.tmp
*~
*.swp
*.swo
Thumbs.db
